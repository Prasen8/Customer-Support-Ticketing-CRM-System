# Backend Configuration (EXAMPLE - Copy to .env and update values)

# Database
DATABASE_URL=sqlite:///./support_crm.db

# API Server
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=True

# CORS
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Application
APP_NAME=Support CRM API
APP_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO
